// ─────────────────────────────────────────────────────────────────────────────
//  PromoDash — Prisma Schema
//  Generator : prisma-client-js
//  Datasource: PostgreSQL (DATABASE_URL in .env)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // bcrypt hash in production
  role      Role
  company   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model PromotionType {
  id          String      @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime    @default(now()) @map("created_at")
  promotions  Promotion[]

  @@map("promotion_types")
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  company   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("clients")
}

model Project {
  id          String      @id @default(uuid())
  name        String
  client      String
  owner       String      @default("Growth Team")
  description String?
  clientUsers String[]    @default([]) @map("client_users")
  createdAt   DateTime    @default(now()) @map("created_at")
  promotions  Promotion[]

  @@map("projects")
}

model Promotion {
  id               String        @id @default(uuid())
  projectId        String        @map("project_id")
  title            String
  typeId           String        @map("type")
  scheduledDate    DateTime      @map("scheduled_date") @db.Date
  status           Status        @default(Draft)
  description      String?
  subjectLine      String?       @map("subject_line")
  contactList      String?       @map("contact_list")
  captions         String[]      @default([])
  currentVersionId String?       @map("current_version_id")
  createdAt        DateTime      @default(now()) @map("created_at")

  project          Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type             PromotionType @relation(fields: [typeId], references: [id])
  versions         Version[]
  comments         Comment[]
  currentVersion   Version?      @relation("CurrentVersion", fields: [currentVersionId], references: [id])

  @@map("promotions")
}

model Version {
  id          String    @id @default(uuid())
  promotionId String    @map("promotion_id")
  version     Int
  label       String
  fileName    String    @map("file_name")
  fileType    FileType  @map("file_type")
  uploadedBy  String    @map("uploaded_by")
  uploadedAt  DateTime  @default(now()) @map("uploaded_at")
  url         String    // relative path: /uploads/<uuid>.ext
  notes       String?

  promotion           Promotion  @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  promotionAsCurrent  Promotion[] @relation("CurrentVersion")

  @@map("versions")
}

model Comment {
  id          String   @id @default(uuid())
  promotionId String   @map("promotion_id")
  author      String
  role        Role
  body        String
  createdAt   DateTime @default(now()) @map("created_at")

  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@map("comments")
}

enum Role {
  admin
  client
}

enum Status {
  Draft
  Pending_Approval @map("Pending Approval")
  Approved
  Revision_Required @map("Revision Required")
  Published
}

enum FileType {
  image
  pdf
}
