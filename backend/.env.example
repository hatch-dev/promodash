PORT=4000

# ── PostgreSQL connection string ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local example:
DATABASE_URL=postgresql://postgres:Hatch@localhost:5433/promotionapproval

# Render/Railway: copy the "Internal Database URL" or "External Database URL"
# DATABASE_URL=postgresql://user:pass@oregon-postgres.render.com/promotion-approval

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=promodash_secret_key

# ── CORS ─────────────────────────────────────────────────────────────────────
# Dev: http://localhost:5173
# Prod: https://your-frontend.vercel.app
CLIENT_URL=http://localhost:5173
