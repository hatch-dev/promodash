PORT=4000

# ── PostgreSQL connection string ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local example:
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/promotion-approval

# Render/Railway: copy the "Internal Database URL" or "External Database URL"
# DATABASE_URL=postgresql://user:pass@oregon-postgres.render.com/promotion-approval

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars

# ── CORS ─────────────────────────────────────────────────────────────────────
# Dev: http://localhost:5173
# Prod: https://your-frontend.vercel.app
CLIENT_URL=http://localhost:5173
